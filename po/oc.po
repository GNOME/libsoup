#: libsoup/cache/soup-cache-input-stream.c:70
msgid "Network stream unexpectedly closed"
msgstr "Lo flux ret s'es arrestat inopinèament"

#: libsoup/cache/soup-cache-input-stream.c:252
msgid "Failed to completely cache the resource"
msgstr "Impossible de metre la ressorsa totalament en cache"

#: libsoup/content-decoder/soup-converter-wrapper.c:197
#, c-format
msgid "Output buffer is too small"
msgstr "La memòria tampon de sortida es tròp pichona"

#: libsoup/http1/soup-body-input-stream.c:157
#: libsoup/http1/soup-body-input-stream.c:195
#: libsoup/http1/soup-body-input-stream.c:256
#: libsoup/http1/soup-body-input-stream.c:276
#: libsoup/http1/soup-message-io-data.c:77
#: libsoup/http2/soup-client-message-io-http2.c:483
#: libsoup/server/http2/soup-server-message-io-http2.c:466
msgid "Connection terminated unexpectedly"
msgstr "La connexion es estada interrompuda d'un biais imprevist"

#: libsoup/http1/soup-body-input-stream.c:212
msgid "Invalid chunk size"
msgstr "Talha del tròç invalida"

#: libsoup/http1/soup-body-input-stream.c:221
msgid "Too large chunk"
msgstr "Tròç tròp gròs"

#: libsoup/http1/soup-body-input-stream.c:523
msgid "Invalid seek request"
msgstr "Requèsta de recèrca invalida"

#: libsoup/http1/soup-body-input-stream.c:551
msgid "Cannot truncate SoupBodyInputStream"
msgstr "Impossible de trocejar lo SoupBodyInputStream"

#: libsoup/http1/soup-client-message-io-http1.c:322
#: libsoup/http1/soup-client-message-io-http1.c:776
#: libsoup/http2/soup-body-input-stream-http2.c:245
#: libsoup/server/http1/soup-server-message-io-http1.c:417
#: libsoup/server/http1/soup-server-message-io-http1.c:911
msgid "Operation would block"
msgstr "L'operacion auriá blocat"

#: libsoup/http1/soup-client-message-io-http1.c:463
msgid "Could not parse HTTP response"
msgstr "Impossible d'analisar la responsa HTTP"

#: libsoup/http1/soup-client-message-io-http1.c:486
msgid "Unrecognized HTTP response encoding"
msgstr "Encodatge de responsa HTTP desconegut"

#: libsoup/http1/soup-client-message-io-http1.c:735
#: libsoup/http1/soup-client-message-io-http1.c:761
#: libsoup/http2/soup-client-message-io-http2.c:1791
#: libsoup/http2/soup-client-message-io-http2.c:1817
msgid "Operation was cancelled"
msgstr "L'operacion es estada anullada"

#: libsoup/http1/soup-message-io-data.c:105
msgid "Header too big"
msgstr "Entèsta tròp granda"

#: libsoup/server/soup-listener.c:265
msgid "Could not import existing socket: "
msgstr "Impossible d'importar lo connectador ret existent : "

#: libsoup/server/soup-listener.c:271
msgid "Can’t import unconnected socket"
msgstr "Impossible d'importar lo connectador ret non connectat"

#: libsoup/server/soup-server.c:1239
msgid "Can’t create a TLS server without a TLS certificate"
msgstr "Impossible de crear un servidor TLS sens un certificat TLS"

#: libsoup/soup-session.c:1134
msgid "Location header is missing or empty in response headers"
msgstr "L’entèsta d’emplaçament es absenta o voida de las entèstas de responsa"

#: libsoup/soup-session.c:1148
#, c-format
msgid "Invalid URI “%s” in Location response header"
msgstr "URI invalid «  %s  » dins l’entèsta de responsa d’emplaçament"

#: libsoup/soup-session.c:1168
msgid "Too many redirects"
msgstr "Tròp de redireccions"

#: libsoup/soup-session.c:1173
msgid "Message was restarted too many times"
msgstr "Lo messatge es estat reaviat tròp de còps"

#: libsoup/soup-session.c:3122 libsoup/soup-session.c:3275
msgid "Message is already in session queue"
msgstr "Lo messatge es ja dins la fila d’espèra"

#: libsoup/soup-session.c:3756
msgid "The server did not accept the WebSocket handshake."
msgstr "Lo servidor a pas acceptat la negociacion WebSocket."

#: libsoup/soup-tld.c:129
msgid "No public-suffix list available."
msgstr "Cap de lista de sufixes publics pas disponibla."

#: libsoup/soup-tld.c:139 libsoup/soup-tld.c:155
msgid "Invalid hostname"
msgstr "Nom d'òste invalid"

#: libsoup/soup-tld.c:146
msgid "Hostname is an IP address"
msgstr "Lo nom d'òste es una adreça IP"

#: libsoup/soup-tld.c:167
msgid "Hostname has no base domain"
msgstr "Lo nom d'òste a pas de domeni de basa"

#: libsoup/soup-tld.c:175
msgid "Not enough domains"
msgstr "Pas pro de domenis"

#: libsoup/websocket/soup-websocket.c:391
#: libsoup/websocket/soup-websocket.c:435
#: libsoup/websocket/soup-websocket.c:451
msgid "Server requested unsupported extension"
msgstr "Lo servidor a demandat una extension pas presa en carga"

#: libsoup/websocket/soup-websocket.c:414
#: libsoup/websocket/soup-websocket.c:606
#, c-format
msgid "Incorrect WebSocket “%s” header"
msgstr "Entèsta WebSocket « %s » incorrècta"

#: libsoup/websocket/soup-websocket.c:415
#: libsoup/websocket/soup-websocket.c:870
#, c-format
msgid "Server returned incorrect “%s” key"
msgstr "Lo servidor a renviat una clau « %s » incorrècta"

#: libsoup/websocket/soup-websocket.c:478
#, c-format
msgid "Duplicated parameter in “%s” WebSocket extension header"
msgstr "Paramètre en doble dins l'extension de l'entèsta del WebSocket « %s »"

#: libsoup/websocket/soup-websocket.c:479
#, c-format
msgid ""
"Server returned a duplicated parameter in “%s” WebSocket extension header"
msgstr ""
"Lo servidor a renviat un paramètre en doble dins l'extension de l'entèsta "
"del WebSocket « %s »"

#: libsoup/websocket/soup-websocket.c:569
#: libsoup/websocket/soup-websocket.c:579
msgid "WebSocket handshake expected"
msgstr "Negociacion WebSocket esperada"

#: libsoup/websocket/soup-websocket.c:587
msgid "Unsupported WebSocket version"
msgstr "Version de WebSocket pas presa en carga"

#: libsoup/websocket/soup-websocket.c:596
msgid "Invalid WebSocket key"
msgstr "Clau WebSocket pas valabla"

#: libsoup/websocket/soup-websocket.c:615
msgid "Unsupported WebSocket subprotocol"
msgstr "Sosprotocòl de WebSocket pas pres en carga"

#: libsoup/websocket/soup-websocket.c:821
msgid "Server rejected WebSocket handshake"
msgstr "Lo servidor a regetat la negociacion WebSocket"

#: libsoup/websocket/soup-websocket.c:829
#: libsoup/websocket/soup-websocket.c:838
msgid "Server ignored WebSocket handshake"
msgstr "Lo servidor a ignorat la negociacion WebSocket"

#: libsoup/websocket/soup-websocket.c:850
msgid "Server requested unsupported protocol"
msgstr "Lo servidor a demandat un protocòl pas pres en carga"

#, c-format
#~ msgid "Could not listen on address %s, port %d: "
#~ msgstr "Impossible d'escotar l'adreça %s sul pòrt %d: "

#~ msgid "Name"
#~ msgstr "Nom"

#~ msgid "Size"
#~ msgstr "Talha"

#~ msgid "Date Modified"
#~ msgstr "Data de modificada"

#~ msgid "Could not parse HTTP request"
#~ msgstr "Impossible d'analisar la requèsta HTTP"

#~ msgid "No URI provided"
#~ msgstr "Cap d'URI pas provesit"

#~ msgid "Invalid “%s” URI: %s"
#~ msgstr "URI « %s » invalida : %s"

#~ msgid "Could not parse URI “%s”"
#~ msgstr "Impossible d'analisar l'URI « %s »"

#~ msgid "Unsupported URI scheme “%s”"
#~ msgstr "L'esquèma d'URI « %s » es pas pres en carga"

#~ msgid "Not an HTTP URI"
#~ msgstr "Es pas un URI HTTP"

#~ msgid "Can’t import non-socket as SoupSocket"
#~ msgstr "Impossible d'importar de contengut non-socket coma SoupSocket"
